
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>BATS Baseball Season 2.0</title>
<style>
body{margin:0;font-family:Arial;background:#0f2747;color:white;text-align:center}
#game{background:#8ecdf5;border:4px solid white;border-radius:12px;display:block;margin:10px auto}
button,select{padding:8px;border-radius:8px}
.card{display:inline-block;background:white;color:#0f2747;padding:8px;border-radius:10px;margin:4px}
.controls button{width:60px;height:60px;font-size:24px}
</style>
</head>
<body>
<h1>BATS Baseball Season 2.0</h1>
<select id="player"></select>
<div id="status"></div>
<div id="cards"></div>
<canvas id="game" width="900" height="500"></canvas>
<div class="controls">
<button id="l">⬅️</button>
<button id="u">⬆️</button>
<button id="d">⬇️</button>
<button id="r">➡️</button>
</div>

<script>
const roster=[
{name:"Clayton Nelms #5",spd:85,pow:72,field:92},
{name:"Brock Larson #29",spd:70,pow:95,field:80},
{name:"Carter Ducote #28",spd:80,pow:82,field:84},
{name:"Sidd Maniere #7",spd:95,pow:65,field:78},
{name:"Luke Turner #23",spd:82,pow:75,field:80},
{name:"Winston Morris #20",spd:78,pow:84,field:86},
{name:"Andrew Chun #17",spd:93,pow:68,field:83},
{name:"Nash Pinter #99",spd:60,pow:99,field:72},
{name:"Fisher Underbrink #13",spd:84,pow:76,field:85},
{name:"Dom Deno #34",spd:72,pow:88,field:79},
{name:"Matthew Stancoven #27",spd:80,pow:81,field:84}
];

const sel=document.getElementById("player");
roster.forEach(p=>{let o=document.createElement("option");o.textContent=p.name;sel.appendChild(o)});

const save=JSON.parse(localStorage.getItem("batsv2")||'{"wins":0,"cards":[]}');
function saveGame(){localStorage.setItem("batsv2",JSON.stringify(save));}

const cards=document.getElementById("cards");
function drawCards(){
cards.innerHTML="";
save.cards.forEach(c=>{
cards.innerHTML+=`<div class="card">${c}<br>⭐ Unlocked</div>`;
});
}
drawCards();

const canvas=document.getElementById("game");
const ctx=canvas.getContext("2d");
let lives=3,inning=1,game=1,score=0,outs=0,laps=0;
let p={x:100,y:100,s:32};
let keys={},balls=[],trophies=[],runner=0;

document.addEventListener("keydown",e=>keys[e.key]=true);
document.addEventListener("keyup",e=>keys[e.key]=false);

function bind(id,key){
let b=document.getElementById(id);
["mousedown","touchstart"].forEach(e=>b.addEventListener(e,x=>{x.preventDefault();keys[key]=true;}));
["mouseup","mouseleave","touchend"].forEach(e=>b.addEventListener(e,x=>{x.preventDefault();keys[key]=false;}));
}
bind("l","ArrowLeft");bind("r","ArrowRight");bind("u","ArrowUp");bind("d","ArrowDown");

function loseLife(){
lives--;
if(lives<=0){game=99;}
}

setInterval(()=>{
if(game===1){
balls.push({x:Math.random()*900,y:-10});
if(Math.random()<0.8)trophies.push({x:Math.random()*860,y:Math.random()*460});
}
},1000);

canvas.addEventListener("click",e=>{
if(game!==2)return;
const r=canvas.getBoundingClientRect();
const x=e.clientX-r.left,y=e.clientY-r.top;
if(x>runner&&x<runner+40&&y>220&&y<260){outs++;runner=0;}
else loseLife();
});

function unlockCard(){
const player=sel.value;
if(!save.cards.includes(player)){
save.cards.push(player);
saveGame();
drawCards();
}
}

function update(){
const stat=roster[sel.selectedIndex].spd/25;
if(keys["ArrowLeft"])p.x-=stat;
if(keys["ArrowRight"])p.x+=stat;
if(keys["ArrowUp"])p.y-=stat;
if(keys["ArrowDown"])p.y+=stat;

if(game===1){
balls.forEach(b=>{
b.y+=5;
let dx=p.x-b.x,dy=p.y-b.y;
if(Math.sqrt(dx*dx+dy*dy)<25){b.y=999;loseLife();}
});
trophies=trophies.filter(t=>{
if(Math.abs(t.x-p.x)<25&&Math.abs(t.y-p.y)<25){score++;return false;}
return true;
});
if(score>=10){game=2;}
}

if(game===2){
runner+=4;
if(runner>900){runner=0;loseLife();}
if(outs>=10){game=3;}
}

if(game===3){
if(p.x>850){laps++;p.x=20;}
if(laps>=5){
unlockCard();
save.wins++;
saveGame();
game=100;
}
}

document.getElementById("status").innerHTML=
`❤️ ${lives} | Inning ${inning} | Game ${game<99?game:"End"} |
Wins Saved: ${save.wins}<br>
${game===1?"Collect 10 trophies: "+score+"/10":""}
${game===2?"Record 10 outs: "+outs+"/10":""}
${game===3?"Run 5 laps: "+laps+"/5":""}`;
}

function drawSprite(x,y,color,name){
ctx.fillStyle=color;
ctx.fillRect(x,y,32,32);
ctx.fillStyle="white";
ctx.fillRect(x+10,y,12,32);
}

function draw(){
ctx.clearRect(0,0,900,500);

if(game===1){
ctx.fillStyle="#c62828";
trophies.forEach(t=>ctx.fillRect(t.x,t.y,18,18));
ctx.fillStyle="white";
balls.forEach(b=>{ctx.beginPath();ctx.arc(b.x,b.y,10,0,7);ctx.fill();});
}

if(game===2){
ctx.fillStyle="green";
ctx.fillRect(0,220,900,40);
ctx.fillStyle="navy";
ctx.fillRect(runner,220,40,40);
ctx.fillStyle="white";
ctx.fillText("Click/Tap Runner",380,120);
}

if(game===3){
ctx.fillStyle="white";
ctx.fillRect(870,0,10,500);
ctx.fillText("Reach finish line 5 times",340,80);
}

drawSprite(p.x,p.y,"#0f2747");

if(game===99||game===100){
ctx.fillStyle="rgba(0,0,0,.7)";
ctx.fillRect(0,0,900,500);
ctx.fillStyle="white";
ctx.font="40px Arial";
ctx.fillText(game===100?"🏆 BATS CHAMPIONS":"Season Over",250,250);
}
}

function loop(){update();draw();requestAnimationFrame(loop);}
loop();
</script>
</body>
</html>
